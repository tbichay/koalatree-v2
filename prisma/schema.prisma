generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth.js Models ──

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  tosAcceptedAt     DateTime?  // AGB akzeptiert
  privacyAcceptedAt DateTime?  // Datenschutz akzeptiert
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  // Relations zu HoererProfil/Geschichte werden nach userId-Migration aktiviert
  // hoererProfile HoererProfil[]
  // geschichten   Geschichte[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ── App Models ──

model HoererProfil {
  id                      String   @id @default(cuid())
  userId                  String
  name                    String
  avatarUrl               String?
  geburtsdatum            DateTime?  // NEU — Geburtsdatum statt festes Alter
  alter                   Int?       // DEPRECATED — bleibt für Abwärtskompatibilität
  geschlecht              String?
  interessen              String[] // PostgreSQL array
  lieblingsfarbe          String?
  lieblingstier           String?
  charaktereigenschaften  String[]
  herausforderungen       String[]
  tags                    String[]   // NEU — Freie Tags vom User
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  geschichten             Geschichte[]
  events                  ProfilEvent[]
  einladungen             ProfilEinladung[]
  zugriffe                ProfilZugriff[]

  @@map("KindProfil")
  @@index([userId])
}

// ── Profil-Sharing ──

enum EinladungStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum ProfilRolle {
  BESITZER
  ZUHOERER
}

model ProfilEinladung {
  id              String           @id @default(cuid())
  hoererProfilId  String
  hoererProfil    HoererProfil     @relation(fields: [hoererProfilId], references: [id], onDelete: Cascade)
  eingeladenEmail String
  eingeladenVon   String           // userId des Besitzers
  status          EinladungStatus  @default(PENDING)
  rolle           ProfilRolle      @default(ZUHOERER)
  sichtbarkeit    String[]         // Konfigurierbar: ["interessen", "charaktereigenschaften"] etc.
  token           String           @unique @default(cuid())
  createdAt       DateTime         @default(now())
  acceptedAt      DateTime?
  acceptedById    String?

  @@index([hoererProfilId])
  @@index([eingeladenEmail])
}

model ProfilZugriff {
  id             String       @id @default(cuid())
  hoererProfilId String
  hoererProfil   HoererProfil @relation(fields: [hoererProfilId], references: [id], onDelete: Cascade)
  userId         String
  rolle          ProfilRolle
  sichtbarkeit   String[]     // Kopiert von Einladung bei Akzeptieren
  createdAt      DateTime     @default(now())

  @@unique([hoererProfilId, userId])
  @@index([userId])
}

model ProfilEvent {
  id              String       @id @default(cuid())
  hoererProfilId  String
  hoererProfil    HoererProfil @relation(fields: [hoererProfilId], references: [id], onDelete: Cascade)
  feld            String       // "interessen", "herausforderungen", "tags", "lieblingstier", etc.
  aktion          String       // "added" | "removed" | "changed"
  wert            String       // der Wert der hinzugefügt/entfernt/geändert wurde
  alterWert       String?      // vorheriger Wert (nur bei "changed")
  createdAt       DateTime     @default(now())

  @@index([hoererProfilId, createdAt])
}

model Geschichte {
  id              String        @id @default(cuid())
  hoererProfilId  String        @map("kindProfilId")
  hoererProfil    HoererProfil  @relation(fields: [hoererProfilId], references: [id], onDelete: Cascade)
  userId          String
  format          String
  ziel            String
  dauer           String
  besonderesThema String?
  titel           String?     // KI-generierter Titel der Geschichte
  text            String
  audioUrl        String?     // Vercel Blob URL
  audioDauerSek   Float?      // Audio-Dauer in Sekunden — gespeichert bei Generierung, erspart preload
  timeline        Json?       // Audio-Timeline: [{ characterId, startMs, endMs }] — wer spricht wann
  zusammenfassung String?     // KI-generierte Kurzzusammenfassung für Koala-Gedächtnis
  shareSlug       String?     @unique // Öffentlicher Share-Link Slug
  videoUrl        String?     // Film-Video Vercel Blob URL
  filmScenes      Json?       // Film-Szenen: FilmScene[] from video-director
  createdAt       DateTime    @default(now())
  generationJob   GenerationJob?
  filmJob         FilmJob?

  @@index([userId])
  @@index([hoererProfilId])
}

// ── Audio Generation Queue ──

enum GenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model GenerationJob {
  id             String           @id @default(cuid())
  geschichteId   String           @unique
  geschichte     Geschichte       @relation(fields: [geschichteId], references: [id], onDelete: Cascade)
  userId         String
  status         GenerationStatus @default(PENDING)
  error          String?          // Last error message
  retryCount     Int              @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())

  @@index([status, createdAt])
  @@index([userId])
}

// ── Film Generation Queue ──

model FilmJob {
  id             String           @id @default(cuid())
  geschichteId   String           @unique
  geschichte     Geschichte       @relation(fields: [geschichteId], references: [id], onDelete: Cascade)
  userId         String
  status         GenerationStatus @default(PENDING)
  progress       String?          // "Szene 3/12: Koda spricht..."
  scenesTotal    Int?
  scenesComplete Int              @default(0)
  error          String?
  retryCount     Int              @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())

  @@index([status, createdAt])
  @@index([userId])
}

// ── Film Project / Series Template ──

model FilmProject {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String?
  style           Json?    // { warmth, musicVolume, crossfade, quality }
  characters      String[] // Character IDs used
  landscapes      String[] // Blob paths of landscape assets
  introVideoUrl   String?  // Reusable intro clip
  outroVideoUrl   String?  // Reusable outro clip
  referenceImages String[] // Style reference images
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}
